  "title": "\u0639\u0646 Saudi Vape | \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0645\u062a\u062c\u0631 \u0648\u0627\u0644\u0634\u062d\u0646 \u0648\u0627\u0644\u062f\u0639\u0645",
  "description": "\u062a\u0639\u0631\u0641 \u0639\u0644\u0649 Saudi Vape\u060c \u0646\u0637\u0627\u0642 \u0627\u0644\u062e\u062f\u0645\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u060c \u0637\u0631\u064a\u0642\u0629 \u0627\u0644\u0639\u0645\u0644\u060c \u0648\u0648\u0633\u0627\u0626\u0644 \u0627\u0644\u062f\u0639\u0645 \u0648\u0627\u0644\u0634\u0631\u0627\u0621 \u062f\u0627\u062e\u0644 \u0627\u0644\u0645\u062a\u062c\u0631.",
