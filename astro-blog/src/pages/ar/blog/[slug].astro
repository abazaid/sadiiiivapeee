---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  // Inline data required for Cloudflare static adapter compatibility
  const slugs = [
    { slug: 'انواع-الفيب-في-السعودية', category: 'أدلة شراء', tags: ['انواع الفيب', 'السعودية', 'سحبات جاهزة', 'بودات', 'نكهات', 'نيكوتين', 'دليل'] },
    { slug: 'هل-الفيب-مسموح-في-السعودية', category: 'أدلة قانونية', tags: ['قانون الفيب', 'السعودية', 'الهيئة العامة للغذاء والدواء', 'شيشة إلكترونية', 'تبغ'] },
    { slug: 'سعر-فيب-السعودية', category: 'أدلة شراء', tags: ['أسعار الفيب', 'السعودية', 'سحبات', 'شيشة إلكترونية', 'نكهات'] },
    { slug: 'شحن-فيب-السعودية', category: 'خدمات', tags: ['شحن', 'توصيل', 'السعودية', 'فيب', 'الرياض', 'جدة'] },
    { slug: 'افضل-شيشة-الكترونية-2025', category: 'مقارنات', tags: ['شيشة إلكترونية', 'أجهزة فيب', 'مقارنة', 'السعودية'] },
    { slug: 'الشيشة-الكترونية-دليل-شامل', category: 'أدلة شراء', tags: ['شيشة إلكترونية', 'دليل', 'أجهزة', 'نكهات'] },
    { slug: 'أفضل-سحبة-جاهزة-في-السعودية', category: 'أدلة شراء', tags: ['سحبات جاهزة', 'السعودية', 'فيب', 'disposable'] },
    { slug: 'أفضل-سحبة-سيجارة-2025', category: 'مقارنات', tags: ['سحبة سيجارة', 'vape pen', 'السعودية'] },
    { slug: 'أفضل-نكهات-ناستي-للسحبة-الالكترونية', category: 'مراجعات', tags: ['ناستي', 'نكهات', 'سولت', 'السعودية'] },
    { slug: 'أفضل-5-نكهات-فيب-من-فيقود-للشيشة-الإلكترونية', category: 'مراجعات', tags: ['فيقود', 'نكهات فيب', 'شيشة إلكترونية'] },
    { slug: 'افضل-6-نكهات-سولت-من-فيقود-للسحبة-الالكترونية', category: 'مراجعات', tags: ['فيقود', 'سولت نيكوتين', 'نكهات'] },
    { slug: 'افضل-سحبة-صغيرة-في-السعودية', category: 'أدلة شراء', tags: ['سحبات صغيرة', 'pods', 'السعودية'] },
    { slug: 'افضل-متجر-فيب-في-الرياض', category: 'أدلة شراء', tags: ['الرياض', 'متجر فيب', 'السعودية'] },
    { slug: 'ارخص-نكهات-فيب', category: 'أدلة شراء', tags: ['نكهات', 'رخيصة', 'السعودية'] },
    { slug: 'مقارنة-بين-أنواع-الشيشة-فيب', category: 'مقارنات', tags: ['مقارنة', 'شيشة إلكترونية', 'أنواع'] },
    { slug: 'افضل-نكهات-الفيب-في-الرياض', category: 'مراجعات', tags: ['الرياض', 'نكهات فيب', 'السعودية'] },
    { slug: 'نكهة-vct-في-سي-تي-ريب-فيب', category: 'مراجعات', tags: ['نكهة VCT', 'Ripe Vapes', 'فانيلا كسترد توباكو', 'نكهات فيب', 'سولت نيكوتين', 'السعودية', 'مراجعة'] },
    { slug: 'سحبات-مزاج-انواعها-واسعارها', category: 'أدلة شراء', tags: ['مزاج', 'سحبات مزاج', 'فيب السعودية', 'سحبات جاهزة', 'ماركة مزاج', 'مزاج فيب', 'دليل شراء'] },
    { slug: 'انواع-السيجارة-الالكترونية-واسعارها', category: 'أدلة شراء', tags: ['انواع السيجارة الالكترونية', 'اسعار السيجارة الالكترونية', 'السعودية', 'سحبات جاهزة', 'بودات', 'فيب', 'دليل أسعار'] },
    { slug: 'قانون-الفيب-في-السعودية', category: 'أدلة قانونية', tags: ['قانون الفيب', 'السعودية', 'نظام مكافحة التدخين', 'هيئة الغذاء والدواء', 'ترخيص بيع فيب', 'عقوبات الفيب', 'الضوابط'] },
    { slug: 'ارخص-فيب-في-السعودية', category: 'أدلة شراء', tags: ['أرخص فيب', 'السعودية', 'سحبات رخيصة', 'فيب اقتصادي', 'أسعار الفيب', 'توفير', 'دليل شراء'] },
    { slug: 'اشكال-الشيشة-الالكترونية', category: 'أدلة شراء', tags: ['اشكال الشيشة', 'شيشة إلكترونية', 'أشكال الفيب', 'أجهزة فيب', 'السعودية', 'دليل شراء', 'مودات'] },
    { slug: 'افضل-نكهة-تبغ-للفيب', category: 'أدلة شراء', tags: ['نكهات تبغ', 'نكهات توباكو', 'السعودية', 'نكهات فيب', 'سولت نيكوتين', 'تبغ', 'دليل شراء'] },
    { slug: 'فوائد-الشيشة-الالكترونية', category: 'أدلة شراء', tags: ['فوائد الشيشة الإلكترونية', 'الشيشة الإلكترونية', 'فيب السعودية', 'بديل الشيشة التقليدية', 'فوائد الفيب', 'شيشة رقمية', 'السعودية'] },
    { slug: 'الشيشة-الالكترونية-للمبتدئين', category: 'أدلة شراء', tags: ['شيشة إلكترونية', 'مبتدئين', 'دليل', 'السعودية', 'أجهزة فيب', 'نيكوتين', 'سحبات'] },
    { slug: 'أفضل-نكهات-الفيب-الباردة', category: 'مراجعات', tags: ['نكهات فيب باردة', 'نكهات مثلجة', 'نعناع فيب', 'ثلج فيب', 'سحبات جاهزة', 'فيب السعودية', 'سولت نيكوتين'] },
    { slug: 'اظرف-نيكوتين-في-السعودية', category: 'أدلة شراء', tags: ['اظرف نيكوتين', 'نيكوتين', 'السعودية', 'ظروف نيكوتين', 'بدائل التدخين', 'فيب السعودية', 'دليل شراء'] },
    { slug: 'نكهات-معسل-الكتروني', category: 'أدلة شراء', tags: ['نكهات معسل الكتروني', 'شيشة إلكترونية', 'نكهات فيب', 'السعودية', 'سوائل فيب', 'دليل شراء', 'VG/PG'] },
  ];
  return slugs.map(entry => ({
    params: { slug: entry.slug },
    props: entry,
  }));
}

const { slug, category, tags } = Astro.props;

// Load markdown content for rendering
const allPosts = Object.values(
  import.meta.glob<{ frontmatter: { title: string; description: string; date: string; slug: string; image: string; draft?: boolean; updated?: string }; Content: any }>('../../../content/blog/*.md', { eager: true })
);
const post = allPosts.find(p => p.frontmatter.slug === slug);
const { title, description, date, image, faqs, products } = post.frontmatter;
---

<BlogPostLayout {title} {description} {date} {image} {slug} {tags} {category} {faqs} {products}>
  <post.Content />
</BlogPostLayout>
