---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/blog/PostCard.astro';
import SeoMeta from '../../../../components/seo/SeoMeta.astro';
import BreadcrumbSchema from '../../../../components/seo/BreadcrumbSchema.astro';
import { AUTHOR } from '../../../../lib/constants';

const allBlogPosts = Object.values(
  import.meta.glob<{ frontmatter: { title: string; description: string; slug: string; date: string; image: string; category: string; author: string; draft?: boolean } }>('../../../../content/blog/*.md', { eager: true })
);
const posts = allBlogPosts
  .filter(p => !p.frontmatter.draft && p.frontmatter.author === 'فريق سعودي فيب')
  .map(p => ({
    title: p.frontmatter.title,
    description: p.frontmatter.description,
    slug: p.frontmatter.slug,
    date: p.frontmatter.date,
    image: p.frontmatter.image,
    category: p.frontmatter.category,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const authorName = 'فريق سعودي فيب';
const authorDesc = 'فريق متخصص في منتجات الفيب والشيشة الإلكترونية في السعودية. نقدم محتوى دقيق ومحدث عن أحدث الأجهزة والنكهات في السوق السعودي.';
const pageTitle = `${authorName} | مدونة فيب السعودية`;
const pageUrl = 'https://saudivapes.com/ar/blog/author/1210468642';
---

<BaseLayout title={pageTitle} description={authorDesc}>
  <SeoMeta
    title={pageTitle}
    description={authorDesc}
    canonical={pageUrl}
  />
  <BreadcrumbSchema items={[
    { name: 'الرئيسية', url: 'https://saudivapes.com/ar' },
    { name: 'المدونة', url: 'https://saudivapes.com/ar/blog' },
    { name: authorName, url: pageUrl },
  ]} />

  <div class="author-page">
    <div class="author-header">
      <div class="author-avatar">SV</div>
      <h1>{authorName}</h1>
      <p class="author-title">{AUTHOR.jobTitle}</p>
      <p class="author-bio">{authorDesc}</p>
      <div class="author-stats">
        <span>{posts.length} مقال</span>
      </div>
    </div>

    <div class="container">
      <div class="posts-grid">
        {posts.map(post => <PostCard {...post} />)}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .author-page { padding-top: 2rem; padding-bottom: 2rem; }
  .author-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 3rem 1rem;
    background: radial-gradient(ellipse 60% 50% at 50% 30%, rgba(124,58,237,0.12) 0%, transparent 60%);
  }
  .author-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Tajawal', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    margin: 0 auto 1rem;
  }
  .author-header h1 { font-size: 1.8rem; color: #f0f0ff; margin-bottom: 0.5rem; }
  .author-title { color: #818cf8; font-weight: 700; margin-bottom: 0.75rem; }
  .author-bio { color: #a0a0b8; max-width: 600px; margin: 0 auto 1rem; font-size: 0.95rem; }
  .author-stats { color: #6b6b80; font-size: 0.85rem; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
</style>
