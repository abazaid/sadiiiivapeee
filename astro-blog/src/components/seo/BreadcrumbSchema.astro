---
export interface Props {
  items: { name: string; url: string }[];
}

const { items } = Astro.props;
---

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@id': item.url,
      name: item.name,
    },
  })),
})} />
